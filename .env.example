# Copy to .env and fill in values. .env is gitignored — never commit real values.

# Discord
BOT_TOKEN=
# Comma-separated channel IDs this bot instance will react in (dev channel(s) here).
# Enable Developer Mode in Discord, then right-click a channel > Copy Channel ID.
ALLOWED_CHANNEL_IDS=

# Postgres (used by both the db container and the bot)
POSTGRES_USER=aangan
POSTGRES_PASSWORD=
POSTGRES_DB=aangan

# LLM
GEMINI_API_KEY=
GEMINI_MODEL=
