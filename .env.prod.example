# Copy to .env.prod and fill in values. .env.prod is gitignored — never commit real values.
# Prod has no local db service, so there are no POSTGRES_USER/PASSWORD/DB vars here.

# Discord
BOT_TOKEN=
# Comma-separated channel IDs this bot instance will react in (prod channel(s) here).
ALLOWED_CHANNEL_IDS=

# Postgres DB connection URL.
DATABASE_URL=

# LLM
GEMINI_API_KEY=
GEMINI_MODEL=
