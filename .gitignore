# Secrets — never commit
.env
.env.*
!.env.example
!.env.prod.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.Python

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Database / backups (durable state lives off-box, not in the working tree)
# NOTE: this must not catch db/migrations/*.sql — those are versioned app source, not dumps.
*.sql
!db/migrations/*.sql
*.dump
pgdata/

